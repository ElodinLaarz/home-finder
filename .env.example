# Copy to .env for local runs (python-dotenv is NOT used; export these or use `uv run --env-file .env ...`).
# In GitHub Actions these live in encrypted repo secrets, injected as env vars.

# RentCast — https://app.rentcast.io/app/api
RENTCAST_API_KEY=

# Mapbox — https://account.mapbox.com/ (default public token works for Isochrone)
MAPBOX_TOKEN=

# Google Maps Platform — enable "Routes API" (and optionally "Street View Static API")
GOOGLE_MAPS_API_KEY=

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Telegram — create a bot with @BotFather, then message it once and read your chat id
# from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Turso (optional — omit both to use a plain local SQLite file at state.path)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
